{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
    
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "drizzle.config.ts"]
}